rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function roleDoc(universityId) {
      return /databases/$(database)/documents/universities/$(universityId)/roles/$(request.auth.uid);
    }

    function isUniversityAdmin(universityId) {
      return isSignedIn()
        && exists(roleDoc(universityId))
        && get(roleDoc(universityId)).data.role == 'admin';
    }

    function isOpenPilotCampus(universityId) {
      return universityId == 'hastings'
        || universityId == 'hastings-demo'
        || universityId == 'sarpy-county'
        || universityId == 'sarpy'
        || universityId == 'sarpy-ne';
    }

    function canCreateEngagementMarker(universityId) {
      return isUniversityAdmin(universityId)
        || isOpenPilotCampus(universityId);
    }

    function canWriteTechnicalAssessment(universityId) {
      return isUniversityAdmin(universityId)
        || isOpenPilotCampus(universityId);
    }

    function canWriteMaintenanceIssue(universityId) {
      return isUniversityAdmin(universityId)
        || isOpenPilotCampus(universityId);
    }

    function canWritePlannerCopilot(universityId) {
      return isUniversityAdmin(universityId)
        || isOpenPilotCampus(universityId);
    }

    match /moves/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /universities/{universityId} {
      allow read: if true;
      allow write: if isUniversityAdmin(universityId);

      match /roles/{userId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isUniversityAdmin(universityId));
        allow write: if isUniversityAdmin(universityId);
      }

      match /markers/{docId} {
        allow read: if true;
        allow create: if canCreateEngagementMarker(universityId);
        allow update, delete: if isUniversityAdmin(universityId);
      }

      match /buildingConditions/{docId} {
        allow read: if true;
        allow write: if isUniversityAdmin(universityId);
      }

      match /buildingAssessments/{docId} {
        allow read: if true;
        allow write: if canWriteTechnicalAssessment(universityId);
      }

      match /maintenanceIssues/{docId} {
        allow read: if true;
        allow create, update, delete: if canWriteMaintenanceIssue(universityId);
      }

      match /plannerCopilotPolicies/{docId} {
        allow read: if canWritePlannerCopilot(universityId);
        allow create, update, delete: if canWritePlannerCopilot(universityId);
      }

      match /plannerCopilotFeedback/{docId} {
        allow read: if canWritePlannerCopilot(universityId);
        allow create, update, delete: if canWritePlannerCopilot(universityId);
      }

      match /floorAdjustments/{docId} {
        allow read: if true;
        allow write: if isUniversityAdmin(universityId);
      }

      match /planningScenarios/{scenarioId} {
        allow read, write: if isUniversityAdmin(universityId);
      }

      match /renoScenarios/{scenarioId} {
        allow read, write: if isUniversityAdmin(universityId);
      }

      match /drawingEntries/{entryId} {
        allow read: if isUniversityAdmin(universityId);
        allow create: if true;
        allow update, delete: if isUniversityAdmin(universityId);
      }

      match /buildings/{buildingId} {
        allow read: if true;
        allow write: if isUniversityAdmin(universityId);

        match /floors/{floorId} {
          allow read: if true;
          allow write: if isUniversityAdmin(universityId);

          match /rooms/{roomId} {
            allow read: if true;
            allow write: if isUniversityAdmin(universityId);
          }
        }
      }
    }
  }
}

